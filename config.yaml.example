# ============================================================
# sp_news_update 設定ファイル
# ここを編集して各種設定を変更してください
# ============================================================

# --- AI設定 ---
# provider: 使用するAIサービスを指定します
#   "rakuten"  → Rakuten AI (社内API)
#   "gemini"   → Google Gemini (無料枠あり。週1配信なら無料で利用可能)
#   "openai"   → OpenAI GPT-4o / GPT-4o mini (従量課金)
#   "claude"   → Anthropic Claude (従量課金)
ai:
  provider: "gemini"                    # ← ここを変更してプロバイダーを切り替え

  # Rakuten AI 設定
  rakuten:
    endpoint: "https://api-opensource-ai.mde.rakuten-it.com"
    api_key: "YOUR_RAKUTEN_API_KEY"
    model: "rakutenai-2.0"

  # Google Gemini 設定（無料枠: gemini-1.5-flash で 100万トークン/日）
  # APIキー取得: https://aistudio.google.com/app/apikey
  gemini:
    api_key: "YOUR_GEMINI_API_KEY"
    model: "gemini-1.5-flash"           # 無料枠対象モデル

  # OpenAI 設定
  openai:
    api_key: "YOUR_OPENAI_API_KEY"
    model: "gpt-4o-mini"                # 安価なモデル

  # Anthropic Claude 設定
  claude:
    api_key: "YOUR_CLAUDE_API_KEY"
    model: "claude-haiku-4-5-20251001"  # 最もコストが低いモデル

  # 共通設定
  max_tokens: 12000
  temperature: 0.3

# --- メール設定 ---
mail:
  smtp_host: "YOUR_SMTP_HOST"           # 実際のSMTPホストに変更してください
  smtp_port: 587
  smtp_user: "YOUR_EMAIL@rakuten.com"   # 送信元メールアドレスに変更してください
  smtp_password: "YOUR_SMTP_PASSWORD"   # SMTPパスワードに変更してください
  use_tls: true
  from_address: "YOUR_EMAIL@rakuten.com"
  from_name: "SP News Update"
  to_address: "YOUR_MAILING_LIST@rakuten.com"  # 配信先メーリングリストに変更してください

# --- スケジュール設定 ---
schedule:
  day_of_week: "monday"   # 実行曜日
  hour: 8                 # 実行時刻（時）
  minute: 0               # 実行時刻（分）

# --- 収集設定 ---
collection:
  max_articles_per_domain: 10  # ドメインごとの最大記事数
  fetch_timeout_seconds: 10    # フェッチタイムアウト（秒）
  days_lookback: 7             # 何日前までの記事を収集するか

# --- 配信ドメイン設定 ---
# active: true にすると配信対象になります
# prompt_file: prompts/ 配下のプロンプトファイル名
domains:
  - id: "security"
    name: "セキュリティ"
    active: true
    prompt_file: "security.yaml"
    sources:
      - name: "JPCERT"
        url: "https://www.jpcert.or.jp/rss/jpcert.rdf"
        type: "rss"
      - name: "IPA 重要なセキュリティ情報"
        url: "https://www.ipa.go.jp/security/rss/alert.rdf"
        type: "rss"
      - name: "Threatpost"
        url: "https://threatpost.com/feed/"
        type: "rss"
      - name: "The Hacker News"
        url: "https://feeds.feedburner.com/TheHackersNews"
        type: "rss"

  - id: "ai_data"
    name: "AI・DATA"
    active: true
    prompt_file: "ai_data.yaml"
    sources:
      - name: "OpenAI News"
        url: "https://openai.com/news/rss.xml"
        type: "rss"
      - name: "OpenAI Product Updates Search"
        url: "https://news.google.com/rss/search?q=OpenAI%20OR%20ChatGPT%20%28launch%20OR%20announces%20OR%20released%20OR%20Images%20OR%20image%20OR%20model%29&hl=ja&gl=JP&ceid=JP:ja"
        type: "rss"
      - name: "OpenAI X/SNS Mentions Search"
        url: "https://news.google.com/rss/search?q=OpenAI%20%28X%20OR%20Twitter%20OR%20livestream%20OR%20teaser%20OR%20posted%29&hl=ja&gl=JP&ceid=JP:ja"
        type: "rss"
      - name: "MIT Technology Review AI"
        url: "https://www.technologyreview.com/feed/"
        type: "rss"
      - name: "VentureBeat AI"
        url: "https://venturebeat.com/category/ai/feed/"
        type: "rss"
      - name: "Google AI Blog"
        url: "https://blog.research.google/feeds/posts/default"
        type: "rss"
      - name: "OpenAI Blog Legacy"
        url: "https://openai.com/blog/rss.xml"
        type: "rss"

  - id: "helpdesk"
    name: "ヘルプデスク"
    active: true
    prompt_file: "helpdesk.yaml"
    sources:
      - name: "Windows IT Pro Blog"
        url: "https://techcommunity.microsoft.com/t5/s/gxcuf89792/rss/Category?category.id=Windows"
        type: "rss"
      - name: "Windows Experience Blog"
        url: "https://blogs.windows.com/windowsexperience/feed/"
        type: "rss"
      - name: "Google Chrome Releases"
        url: "https://chromereleases.googleblog.com/feeds/posts/default"
        type: "rss"
      - name: "ITmedia PC USER"
        url: "https://rss.itmedia.co.jp/rss/2.0/pcuser.xml"
        type: "rss"
